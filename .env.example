# ============================================
# SKIN'EPIL — Variables d'environnement
# Configurez ces valeurs dans Vercel Dashboard > Settings > Environment Variables
# ============================================

# --- Authentification admin ---
# Mot de passe pour accéder au dashboard admin
ADMIN_PASSWORD=skinepil2026

# Clé secrète pour signer les tokens d'authentification (changez-la !)
AUTH_SECRET=votre-cle-secrete-unique-ici

# --- Vercel KV (Redis) ---
# Ces variables sont ajoutées automatiquement quand vous liez un KV Store dans Vercel
# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...
# KV_REST_API_READ_ONLY_TOKEN=...

# --- Notifications email (optionnel) ---
# Créez un compte gratuit sur https://resend.com
# 100 emails/jour gratuits
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email où recevoir les notifications de réservation
ADMIN_EMAIL=votre-email@exemple.com
